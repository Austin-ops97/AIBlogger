# Copy this file to .env.local and fill in your values
ANTHROPIC_API_KEY=your_anthropic_api_key_here
JWT_SECRET=your-random-secret-here
# ADMIN_USERNAME=austin
# ADMIN_PASSWORD_HASH=

# Postgres (required). On Vercel: Storage → Neon → connect project (sets POSTGRES_URL, DATABASE_URL, …).
# Local: vercel env pull   OR   paste a connection string below.
# If queries fail locally, the app strips channel_binding=require from Neon template URLs automatically.
# POSTGRES_URL=postgresql://...
# DATABASE_URL=postgresql://...
